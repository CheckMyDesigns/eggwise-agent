# Copy to eggwise_agent/.env (or set as environment variables).
# No secrets here: the agent authenticates to Vertex via Application Default
# Credentials (local: gcloud auth application-default login; Cloud Run: the
# runtime service account).
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
